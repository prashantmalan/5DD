{
  "name": "claude-steward",
  "displayName": "Claude Steward — 5DD Plan",
  "description": "Cut your Claude API costs to $5 a day. Claude Steward runs silently in the background — routing requests to the cheapest capable model, caching repeated queries, compressing prompts, and enforcing interaction governance so nothing leaks and nothing wastes.",
  "version": "1.3.20",
  "publisher": "PrashantMalan",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-optimizer/claude-token-optimizer"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "token",
    "optimization",
    "ai"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeOptimizer.showDashboard",
        "title": "Claude Optimizer: Show Dashboard"
      },
      {
        "command": "claudeOptimizer.toggle",
        "title": "Claude Optimizer: Toggle ON/OFF"
      },
      {
        "command": "claudeOptimizer.startProxy",
        "title": "Claude Optimizer: Start Proxy Server"
      },
      {
        "command": "claudeOptimizer.stopProxy",
        "title": "Claude Optimizer: Stop Proxy Server"
      },
      {
        "command": "claudeOptimizer.clearCache",
        "title": "Claude Optimizer: Clear Cache"
      },
      {
        "command": "claudeOptimizer.optimizeSelection",
        "title": "Claude Optimizer: Optimize Selected Prompt"
      }
    ],
    "configuration": {
      "title": "Claude Token Optimizer",
      "properties": {
        "claudeOptimizer.proxyPort": {
          "type": "number",
          "default": 8787,
          "description": "Local proxy server port (set ANTHROPIC_BASE_URL=http://localhost:8787)"
        },
        "claudeOptimizer.enableCache": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic response caching"
        },
        "claudeOptimizer.cacheThreshold": {
          "type": "number",
          "default": 0.92,
          "description": "Similarity threshold for cache hits (0.0 - 1.0)"
        },
        "claudeOptimizer.enableModelRouter": {
          "type": "boolean",
          "default": true,
          "description": "Auto-route simple queries to cheaper models (haiku)"
        },
        "claudeOptimizer.enablePiiRedaction": {
          "type": "boolean",
          "default": true,
          "description": "Detect and redact API keys, emails, phone numbers, and credit card numbers before sending to Anthropic"
        },
        "claudeOptimizer.modelRouterMode": {
          "type": "string",
          "enum": [
            "aggressive",
            "balanced",
            "conservative"
          ],
          "default": "balanced",
          "description": "Model routing strategy: aggressive (minimize cost), balanced (cost/quality), conservative (preserve quality)"
        },
        "claudeOptimizer.minimumModel": {
          "type": "string",
          "enum": [
            "claude-haiku-4-5",
            "claude-sonnet-4-6",
            "claude-opus-4-6"
          ],
          "default": null,
          "description": "Never route below this model (null = no floor)"
        },
        "claudeOptimizer.allowHaikuFor": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "simple-qa",
            "formatting"
          ],
          "description": "Tags/patterns where Haiku is permitted (e.g., 'simple-qa', 'formatting', 'translation')"
        },
        "claudeOptimizer.enablePromptCompression": {
          "type": "boolean",
          "default": true,
          "description": "Compress prompts to reduce token usage"
        },
        "claudeOptimizer.maxContextMessages": {
          "type": "number",
          "default": 20,
          "description": "Max messages to keep in context window before summarizing"
        },
        "claudeOptimizer.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Anthropic API key (or set ANTHROPIC_API_KEY env var)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeOptimizer",
          "title": "Claude Token Optimizer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claudeOptimizer": [
        {
          "type": "webview",
          "id": "claudeOptimizer.statsView",
          "name": "Token Stats"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "claudeOptimizer.optimizeSelection",
          "when": "editorHasSelection",
          "group": "claudeOptimizer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "node-cache": "^5.1.2",
    "tiktoken": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/test/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/test/__mocks__/vscode.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
